<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
     <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
     <div class="p-10 w-full min-h-screen bg-zinc-900 text-white">
          <a class="px-3 py-2 bg-blue-500 rounded-lg mb-2 inline-block" href="/login">login</a>
          <h3 class="text-3xl mb-2">Create Account</h3>
      <form action="/register" method="post">
           <input class="px-3 py-2 bg-transparent rounded-lg border-2 border-zinc-700 outline-none" type="text" placeholder="Name..." name="name">
           <input class="px-3 py-2 bg-transparent rounded-lg border-2 border-zinc-700 outline-none" type="text" placeholder="Username..." name="username">
           <input class="px-3 py-2 bg-transparent rounded-lg border-2 border-zinc-700 outline-none" type="password" placeholder="Password" name="password">
           <input class="px-3 py-2 bg-transparent rounded-lg border-2 border-zinc-700 outline-none" type="number" placeholder="Age.." name="age">
           <input class="px-3 py-2 bg-transparent rounded-lg border-2 border-zinc-700 outline-none" type="text" placeholder="email" name="email">
           <input class="px-3 py-2 bg-blue-500 rounded-md" type="submit" value="Create Account">
     </form>     
</div>
</body>
</html>