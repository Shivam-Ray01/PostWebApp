<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
     <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
     <div class="p-5 w-full min-h-screen bg-zinc-900 text-white">
        <div class="w-full flex justify-end">
               <a class="px-3 py-2 bg-red-500 rounded-lg mb-2 inline-block" href="/logout">Logout</a>
          </div>
            <h5 class="mb-4">Edit your post...</h5>     
          <form action="/update/<%=post._id%>" method="post">
        <textarea class="resize-none border-2 border-zinc-700 bg-transparent rounded-lg px-3 w-1/3 outline-none block" name="content" placeholder="Type Your post..."><%=post.content%></textarea>     
         <input class="bg-yellow-500 px-3 py-2 rounded-lg block mt-2 w-40 text-sm text-black" type="submit" value="Update Post">
           </form> 
       </div>
</body>
</html>


