<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login</title>

    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gradient-to-br from-blue-900 via-pink-900 to-white min-h-screen flex items-center justify-center">

    <!-- Card -->
    <div class="p-10 text-white w-96 bg-white/10 backdrop-blur-lg rounded-2xl shadow-2xl border border-white/20">

        <h3 class="text-3xl mb-6 font-bold text-center tracking-wide">
            Login Account
        </h3>

        <form action="/login" method="post" class="space-y-5">

            <!-- Email -->
            <input 
                class="w-full px-4 py-2 bg-white/20 rounded-lg border border-white/30 outline-none 
                       focus:ring-2 focus:ring-pink-400 focus:border-transparent 
                       placeholder-gray-300 transition duration-300"
                type="email" 
                placeholder="Email" 
                name="email"
                required
            >

            <!-- Password -->
            <input 
                class="w-full px-4 py-2 bg-white/20 rounded-lg border border-white/30 outline-none 
                       focus:ring-2 focus:ring-pink-400 focus:border-transparent 
                       placeholder-gray-300 transition duration-300"
                type="password" 
                placeholder="Password" 
                name="password"
                required
            >
 
            <!-- Button -->
            <input 
                class="w-full px-4 py-2 bg-gradient-to-r from-pink-500 to-blue-500 rounded-lg 
                       font-semibold cursor-pointer 
                       hover:scale-105 hover:shadow-lg 
                       active:scale-95 
                       transition duration-300"
                type="submit" 
                value="Login Account"
            >

        </form>

        <!-- Optional -->
        <p class="text-sm text-gray-300 text-center mt-5">
            Don't have an account? 
            <a href="/register" class="text-pink-400 hover:underline">Register</a>
        </p>

    </div>

</body>
</html>