
 <!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gradient-to-br from-zinc-900 via-black to-zinc-800 text-white">

<div class="p-6 min-h-screen">

    <!-- Navbar -->
    <div class="flex justify-between items-center mb-6">
        <h2 class="text-xl font-semibold tracking-wide">My Feed</h2>
        <a class="px-4 py-2 bg-red-500 hover:bg-red-600 transition rounded-lg shadow-lg" href="/logout">
            Logout
        </a>
    </div>

    <!-- User Info -->
    <div class="flex items-center gap-4 mb-6 bg-white/5 backdrop-blur-md p-4 rounded-xl shadow-md w-fit">
        <div class="w-12 h-12 rounded-full overflow-hidden border-2 border-blue-500">
            <img class="w-full h-full object-cover" src="/images/uploads/<%= user.profilepic %>" alt="">
        </div>
        <h3 class="text-2xl">
            <span class="font-light text-zinc-400">Hello,</span> <%= user.name %>
        </h3>
    </div>

    <!-- Create Post -->
    <div class="bg-white/5 backdrop-blur-md p-5 rounded-xl shadow-lg w-1/3 mb-10">
        <h5 class="mb-3 text-zinc-300">Write your thoughts...</h5>

        <form action="/post" method="post">
            <textarea 
                class="resize-none border border-zinc-700 bg-transparent rounded-lg px-3 py-2 w-full outline-none focus:ring-2 focus:ring-blue-500 transition"
                name="content"
                placeholder="What's on your mind?"></textarea>

            <input 
                class="bg-blue-500 hover:bg-blue-600 px-4 py-2 rounded-lg mt-3 text-sm cursor-pointer transition shadow-md"
                type="submit"
                value="Create Post">
        </form>
    </div>

    <!-- Posts -->
    <div class="posts">
        <h3 class="text-zinc-400 mb-4">Your Posts</h3>

        <div class="flex flex-col gap-4 max-h-[500px] overflow-y-auto pr-2">

            <% user.posts.reverse().forEach((post)=> { %>

            <div class="bg-white/5 backdrop-blur-md p-4 rounded-xl shadow-md w-1/3 hover:scale-[1.02] transition">

                <h4 class="text-blue-400 mb-1 font-medium">
                    <%= user.username %>
                </h4>

                <p class="text-zinc-200"><%= post.content %></p>

                <div class="flex items-center justify-between mt-3">

                    <!-- Likes -->
                    <small class="text-zinc-400">
                        ❤️ <%= post.likes.length %>
                    </small>

                    <!-- Buttons -->
                    <div class="flex gap-4 text-sm">

                        <a class="hover:text-blue-400 transition"
                           href="/like/<%= post._id %>">
                           <%= post.likes.indexOf(user._id) === -1 ? "Like" : "Unlike" %>
                        </a>

                        <a class="hover:text-yellow-400 transition"
                           href="/edit/<%= post._id %>">
                           Edit
                        </a>

                        <form action="/delete" method="post">
                            <input type="hidden" name="postid" value="<%= post._id %>">
                            <button type="submit"
                                class="text-red-400 hover:text-red-600 transition">
                                Delete
                            </button>
                        </form>

                    </div>

                </div>
            </div>

            <% }) %>

        </div>
    </div>

</div>

</body>
</html>